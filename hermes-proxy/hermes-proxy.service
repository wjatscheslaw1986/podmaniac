[Unit]
Description=Hermes Model Proxy Container
After=default.target

ExecStart=/usr/bin/podman run \
    --rm \
    --name hermes-proxy \
    -v %h/.local/share/hermes-socket:/socket:Z \
    localhost/hermes-proxy:latest

ExecStop=/usr/bin/podman stop -t 10 hermes-proxy

Restart=always
RestartSec=5

[Install]
WantedBy=default.target
